<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.hylee.phms.server.mapper.SportDictionaryMapper">

    <resultMap id="optionMap" type="org.hylee.phms.server.persistence.SportDictionaryOptionDO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
    </resultMap>

    <select id="selectAudiences" resultMap="optionMap">
        SELECT id, name
        FROM sport_audience
        ORDER BY id ASC
    </select>

    <select id="selectAudienceByName" resultMap="optionMap">
        SELECT id, name
        FROM sport_audience
        WHERE name = #{name}
        LIMIT 1
    </select>

    <select id="selectEquipments" resultMap="optionMap">
        SELECT id, name
        FROM sport_equipment
        ORDER BY id ASC
    </select>

    <select id="selectEquipmentByName" resultMap="optionMap">
        SELECT id, name
        FROM sport_equipment
        WHERE name = #{name}
        LIMIT 1
    </select>

    <select id="selectBenefits" resultMap="optionMap">
        SELECT id, name
        FROM sport_benefit
        ORDER BY id ASC
    </select>

    <select id="selectBenefitByName" resultMap="optionMap">
        SELECT id, name
        FROM sport_benefit
        WHERE name = #{name}
        LIMIT 1
    </select>

    <insert id="insertAudience">
        INSERT IGNORE INTO sport_audience(name)
        VALUES (#{name})
    </insert>

    <insert id="insertEquipment">
        INSERT IGNORE INTO sport_equipment(name)
        VALUES (#{name})
    </insert>

    <insert id="insertBenefit">
        INSERT IGNORE INTO sport_benefit(name)
        VALUES (#{name})
    </insert>

    <select id="countAudienceIds" resultType="long">
        <choose>
            <when test="ids != null and ids.size() > 0">
                SELECT COUNT(1)
                FROM sport_audience
                WHERE id IN
                <foreach collection="ids" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </when>
            <otherwise>
                SELECT 0
            </otherwise>
        </choose>
    </select>

    <select id="countEquipmentIds" resultType="long">
        <choose>
            <when test="ids != null and ids.size() > 0">
                SELECT COUNT(1)
                FROM sport_equipment
                WHERE id IN
                <foreach collection="ids" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </when>
            <otherwise>
                SELECT 0
            </otherwise>
        </choose>
    </select>

    <select id="countBenefitIds" resultType="long">
        <choose>
            <when test="ids != null and ids.size() > 0">
                SELECT COUNT(1)
                FROM sport_benefit
                WHERE id IN
                <foreach collection="ids" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </when>
            <otherwise>
                SELECT 0
            </otherwise>
        </choose>
    </select>
</mapper>
